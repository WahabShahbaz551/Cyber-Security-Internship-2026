<!DOCTYPE html>
<html>
<head>
    <title>Vulnerable App - Week 1</title>
    <style>
        body { font-family: sans-serif; margin: 50px; line-height: 1.6; }
        .box { border: 1px solid #ccc; padding: 20px; margin-bottom: 20px; border-radius: 8px; }
        input { display: block; margin: 10px 0; padding: 8px; width: 250px; }
        button { background: #2ecc71; color: white; border: none; padding: 10px 20px; cursor: pointer; }
    </style>
</head>
<body>
    <h1>Security Testing Lab</h1>

    <div class="box">
        <h3>Login</h3>
        <form action="/login" method="POST">
            <input type="text" name="username" placeholder="Username" required>
            <input type="password" name="password" placeholder="Password" required>
            <button type="submit">Login</button>
        </form>
    </div>

    <div class="box">
        <h3>Update Profile Bio</h3>
        <form action="/update-bio" method="POST">
            <input type="text" name="username" placeholder="Your Username" required>
            <textarea name="bio" placeholder="Write something about yourself..." rows="4" cols="30"></textarea><br><br>
            <button type="submit">Update Bio</button>
        </form>
    </div>
</body>
</html>